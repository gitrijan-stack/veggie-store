# ── Server ──────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── JWT Secret ────────────────────────────────────────
JWT_SECRET=veggie_store_super_secret_key_change_this

# ── Admin / Seller Credentials ───────────────────────
SELLER_EMAIL=admin@veggiestore.com
SELLER_PASSWORD=admin123

# ── MySQL Workbench Connection ───────────────────────
# Default local MySQL Workbench settings — update if yours differ
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=9741
DB_NAME=veggie_store

# ── Frontend URL (for CORS) ──────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Khalti ePayment (sandbox) ────────────────────────
# https://docs.khalti.com — get your own live_secret_key from
# test-admin.khalti.com (sandbox) and swap KHALTI_BASE_URL to
# https://khalti.com/api/v2/ with the admin.khalti.com key for production.
# The value below is Khalti's public sandbox test key from their docs —
# replace it with your own merchant sandbox key.
KHALTI_SECRET_KEY=fd9a404812f8455e8bfa35cc6f3cd7af
KHALTI_BASE_URL=https://dev.khalti.com/api/v2/
